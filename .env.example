# Copy to .env.local for local development with `vercel dev`.
# On Vercel, set these in: Project → Settings → Environment Variables.
# NEVER commit your real key.

# Required: your Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Optional: override the model (defaults to gemini-2.5-flash).
# Examples: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3.5-flash
GEMINI_MODEL=gemini-2.5-flash
